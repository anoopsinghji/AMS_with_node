<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>School Attendance System - Login</title>
    <link rel="icon" type="image/svg+xml" href="/images/ams-logo.svg" />
    <link rel="stylesheet" href="/css/styles.css" />
    
    <!-- SweetAlert2 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="/css/sweetalert-custom.css" />
    
    <!-- Toastr Notifications -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
  </head>
  <body class="login-page">
    <div class="login-container">
      <!-- Left Side - Branding -->
      <div class="login-branding">
        <div class="branding-content">
          <img src="/images/illustration.svg" alt="Illustration" class="illustration">
          <h2 class="branding-title">Attendance Management System</h2>
          <p class="branding-subtitle">Login to access your account</p>
        </div>
      </div>
      
      <!-- Right Side - Login Form -->
      <div class="login-form-section">
        <div class="login-form-wrapper">
          <div class="form-header">
            <h1>Login</h1>
            <p>Enter your account details</p>
          </div>
          
          <form id="loginForm" class="login-form">
            <div class="form-group">
              <label for="id">Username</label>
              <div class="input-wrapper">
                <input id="id" name="id" type="text" placeholder="Enter your ID" required />
              </div>
            </div>
            
            <div class="form-group">
              <label for="password">Password</label>
              <div class="input-wrapper">
                <input id="password" name="password" type="password" placeholder="Enter your password" required />
                <i class="fas fa-eye-slash"></i>
              </div>
            </div>

            <!-- <a href="#" class="forgot-password">Forgot Password?</a> -->
            
            <button type="submit" class="login-button">
              <span>Login</span>
            </button>
          </form>
          
          <p id="message" class="message"></p>
        </div>
      </div>
    </div>

    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <!-- Toastr -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/2.1.4/toastr.min.js"></script>
    <!-- Custom Script -->
    <script src="/js/login.js"></script>
  </body>
</html>
